rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    
    // Extremely secure Admin validation: Only documents inside the 'admins' collection 
    // whose ID matches the authenticating user uid indicate an admin.
    function isAdmin() { return isSignedIn() && (request.auth.token.admin == true || exists(/databases/$(database)/documents/admins/$(request.auth.uid))); }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if false;
    }

    match /settings/{docId} {
      allow read: if true; // Public configuration for frontend (like layout)
      allow write: if isAdmin(); // Concrete security: Only admin can edit site layout
    }

    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /linkClaims/{claimId} {
      allow read: if isSignedIn() && (claimId.matches(request.auth.uid + '_.*') || isAdmin());
    }

    match /rewardCodes/{codeId} {
      allow read: if isAdmin(); // تم التغيير هنا لحظر القراءة من المستخدم العادي
      allow write: if isAdmin();
    }

    match /capcutAccounts/{accountId} {
      allow read, write: if isAdmin();
    }

    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    match /userIntents/{intentId} {
      allow read, write: if false;
    }

    match /adminLogs/{logId} {
      allow read, write: if false;
    }
  }
}
