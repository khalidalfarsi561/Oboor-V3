rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    
    // Extremely secure Admin validation: Only documents inside the 'admins' collection 
    // whose ID matches the authenticating user uid indicate an admin.
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn(); // Allow reading to check if admin
      allow write: if false; // Only manageable from backend
    }

    match /settings/{docId} {
      allow read: if true; // Public configuration for frontend (like layout)
      allow write: if isAdmin(); // Concrete security: Only admin can edit site layout
    }

    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /linkClaims/{claimId} {
      allow read: if isSignedIn() && (claimId.matches(request.auth.uid + '_.*') || isAdmin());
      allow delete: if isSignedIn() && claimId.matches(request.auth.uid + '_.*');
    }

    match /rewardCodes/{codeId} {
      allow read: if isSignedIn(); 
      allow write: if isAdmin();
    }

    match /stockNotifications/{docId} {
      allow read, write: if isSignedIn() && docId.matches(request.auth.uid + '_.*');
    }

    match /userNotifications/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}
